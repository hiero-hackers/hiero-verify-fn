#!/usr/bin/env bash
#
# Pre-commit checks for hiero-verify-fn — the fast subset of CI.
#
# Enable once per clone:
#   git config core.hooksPath .githooks
#
# Bypass for a work-in-progress commit with:  git commit --no-verify
set -euo pipefail

# Skip entirely unless Rust or Cargo files are staged.
if ! git diff --cached --name-only --diff-filter=ACM \
        | grep -qE '\.rs$|(^|/)Cargo\.(toml|lock)$'; then
    exit 0
fi

echo "pre-commit › cargo fmt --check"
cargo fmt --check

echo "pre-commit › cargo clippy --all-targets -- -D warnings"
cargo clippy --all-targets -- -D warnings

echo "pre-commit › ok"
